<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    android:paddingBottom="200dp"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- CardView para información principal de la receta -->
        <androidx.cardview.widget.CardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Imagen de fondo -->

                <ImageView
                    android:id="@+id/imgHeaderReceta"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

                <!-- Oscurece un poco la imagen -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#33000000"/>

                <!-- Todo el contenido -->

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- ========================= -->
                    <!-- TITULO                    -->
                    <!-- ========================= -->

                    <TextView
                        android:id="@+id/txtTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Enchiladas Verdes"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <!-- ========================= -->
                    <!-- COINCIDENCIA              -->
                    <!-- ========================= -->

                    <TextView
                        android:id="@+id/txtCoincidencia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coincidencia 35%"
                        android:textColor="#FFD54F"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <!-- ========================= -->
                    <!-- PANEL SUPERIOR            -->
                    <!-- ========================= -->
                    <LinearLayout
                        android:id="@+id/layoutDatos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingTop="80dp">

                        <!-- Tiempo -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/ic_clock_bg"/>
                            <TextView
                                android:id="@+id/txtTiempo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="50 min"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Nivel -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/ic_nivel"/>

                            <TextView
                                android:id="@+id/txtNivel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fácil"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Costo -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/ic_dinero"/>

                            <TextView
                                android:id="@+id/txtCosto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$45"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Tipo -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/ic_comida"/>

                            <TextView
                                android:id="@+id/txtTipo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mexicana"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- ========================= -->
                    <!-- CALIFICACION              -->
                    <!-- ========================= -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="14dp"
                        android:gravity="center"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/txtCalificacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.0"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"/>

                        <RatingBar
                            android:id="@+id/ratingReceta"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:rating="4"
                            android:stepSize="0.5"/>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <!-- PANEL DATO GOURMEET -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_panel_receta"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dato Gourmeet"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:fontFamily="@font/caviardreams"/>

                <TextView
                    android:id="@+id/tvDatoGourmet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="30 g de proteína"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:fontFamily="@font/caviardreams"/>

            </LinearLayout>

            <!-- PANEL DESCRIPCIÓN -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_panel_receta_derecha"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:fontFamily="@font/caviardreams"/>

                <TextView
                    android:id="@+id/tvRecetaDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="7"
                    android:ellipsize="end"
                    android:text="Descripción de la receta..."
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:fontFamily="@font/caviardreams"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingredientes"
                android:textStyle="bold"
                android:textSize="22sp"
                android:fontFamily="@font/caviardreams"
                android:textColor="#222"/>



            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvIngredientes"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:paddingStart="6dp"
                android:paddingEnd="18dp"
                android:overScrollMode="never"
                android:scrollbars="horizontal"/>

        </LinearLayout>


        <androidx.cardview.widget.CardView
            android:id="@+id/cardPreparacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Cabecera con título y contador -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👨‍🍳 Preparación"
                        android:fontFamily="@font/caviardreams"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#333333"/>

                </LinearLayout>



                <!-- Área para mostrar el paso actual -->
                <LinearLayout
                    android:id="@+id/containerPasoActual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_paso"
                    android:padding="20dp">

                        <TextView
                            android:id="@+id/tvDescripcionPaso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Aquí aparecerá el paso"
                            android:textSize="18sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:lineSpacingExtra="5dp"/>



                    <!-- Barra de progreso -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:layoutDirection="rtl">


                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/containerIndicadores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:orientation="horizontal"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerTodo"
                        android:layout_width="140dp"
                        android:layout_height="42dp"
                        android:backgroundTint="#177AFF"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:text="Ver todo"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:cornerRadius="22dp"/>
                    <LinearLayout
                        android:id="@+id/containerTodosLosPasos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp">
                <!-- 🔥 Miniatura -->
                <ImageView
                    android:id="@+id/imgPreviewVideo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
                <!-- 🔥 Ícono Play -->
                <ImageView
                    android:id="@+id/imgPlay"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_youtube"
                    android:alpha="0.9"/>
            </FrameLayout>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 🔥 Título -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💬 Comentarios"
                    android:fontFamily="@font/caviardreams"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="12dp"/>

                <!-- 🔥 RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerComentarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
                <!-- 🔥 Apartado escribir comentario -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <!-- Usuario android:background="@drawable/circle_bg" -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_user"
                            android:scaleType="centerCrop"
                            />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Usuario"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#000000"/>

                            <!-- Ranking bar -->
                            <RatingBar
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:numStars="5"
                                android:stepSize="1"
                                android:rating="0"
                                android:isIndicator="true"
                                android:progressTint="@android:color/holo_orange_dark"
                            android:progressBackgroundTint="@android:color/darker_gray"
                            android:secondaryProgressTint="@android:color/holo_orange_dark"
                            />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Campo comentario + enviar  android:background="@drawable/edit_bg" -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"

                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <EditText
                            android:id="@+id/editComentario"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Escribe tu comentario"
                            android:maxLength="150"
                            android:background="@android:color/transparent"
                            android:textColor="#000000"
                            android:textColorHint="#888888"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"/>

                        <ImageView
                            android:id="@+id/btnEnviarComentario"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_send"
                            android:padding="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Enviar comentario"/>

                    </LinearLayout>

                    <!-- Contador -->
                    <TextView
                        android:id="@+id/txtContador"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/150"
                        android:layout_gravity="end"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>