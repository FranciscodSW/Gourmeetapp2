<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Registro">
    <!-- Franja superior azul -->
    <LinearLayout
        android:id="@+id/headerTop"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="#0E90E4"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logo_circular"
            android:contentDescription="Logo"/>

        <!-- Texto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu consumo responsable inicia hoy"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>
    </LinearLayout>
    <!-- Contenedor tipo card -->
    <LinearLayout
        android:id="@+id/layoutRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="24dp"
        android:background="@drawable/bg_card"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.912">
            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/caviardreams"
                android:text="Crea tu cuenta"
                android:textSize="26sp"
                android:textStyle="bold" />
            <!-- Nombre -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                app:boxStrokeColor="#0E90E4"
                app:hintTextColor="#0E90E4"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"/>
            </com.google.android.material.textfield.TextInputLayout>
            <!-- Correo -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Correo"
                app:boxStrokeColor="#0E90E4"
                app:hintTextColor="#0E90E4"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>
            <!-- Contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Contraseña"
                app:boxStrokeColor="#0E90E4"
                app:endIconMode="password_toggle"
                app:hintTextColor="#0E90E4"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirmar contraseña -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Confirmar contraseña"
                app:boxStrokeColor="#0E90E4"
                app:endIconMode="password_toggle"
                app:hintTextColor="#0E90E4"
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>
            <!-- Mensaje error -->
            <TextView
                android:id="@+id/txtError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#D32F2F"
                android:visibility="gone" />

            <!-- Botón -->
            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#0E90E4"
                android:fontFamily="@font/caviardreams"
                android:text="Confirmar datos"
                android:textColor="#FFFFFF" />
            <!-- Separador -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="O continuar con"
                android:textColor="#888888" />

            <!-- Fila de iconos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnGoogle"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/ic_gmail"
                    android:contentDescription="Google"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_gmail" />

                <ImageButton
                    android:id="@+id/btnFacebook"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/ic_facebook"
                    android:contentDescription="Facebook"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_facebook" />

                <ImageButton
                    android:id="@+id/btnTictok"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/ic_tiktok"
                    android:contentDescription="Apple"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_tiktok" />
            </LinearLayout>
        </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollPersonalizar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <LinearLayout
        android:id="@+id/layoutPersonalizar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerTop">
        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="Personaliza tu usuario"
            android:fontFamily="@font/caviardreams"
            android:textSize="24sp"
            android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionAvatar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Seleccionar avatar"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_avatar"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <!-- Experiencia -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionNivel"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Seleccionar Nivel"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_nivel"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btneditSeleccionEdad"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Selecciona tu Edad"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_calendario"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btneditUbicacion"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Ubicacion"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_ubicacion"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <!-- Ubicación -->
        <Button
            android:id="@+id/btnFin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#0E90E4"
            android:text="Confirmar"
            android:fontFamily="@font/caviardreams"
            android:textColor="#FFFFFF" />
    </LinearLayout>
    <!-- contendeor para la parte de restricciones-->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollRestricciones"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <LinearLayout
        android:id="@+id/layoutrestricciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerTop">
        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="Restricciones"
            android:fontFamily="@font/caviardreams"
            android:textSize="24sp"
            android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionalergias"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Seleccionar alergias"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_alergia"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <!-- Experiencia -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionCultura"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Restricciones culturales"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_cultura"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btneditSeleccionAlimento"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="Restricciones alimenticias"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_alimentos"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btneditintolerancias"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:text="intolerancias"
            android:fontFamily="@font/caviardreams"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:icon="@drawable/ic_intolerancia"
            app:iconPadding="8dp"
            app:iconTint="#0E90E4"
            app:iconGravity="textStart"/>
        <!-- Ubicación -->
        <Button
            android:id="@+id/btnFinRes"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#0E90E4"
            android:text="Confirmar"
            android:fontFamily="@font/caviardreams"
            android:textColor="#FFFFFF" />
    </LinearLayout>
    <!-- contenedor para la parte inferio-->
    <LinearLayout
        android:id="@+id/contenedorInferior"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="10dp"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 🔹 Barra de arrastre (NO debe hacer scroll) -->
        <LinearLayout
            android:id="@+id/barraArrastre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="12dp">

            <View
                android:layout_width="50dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_arrastre_rectangulo"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvExpandirContraer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desliza para expandir"
                android:fontFamily="@font/caviardreams"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>
        <!-- 🔥 SCROLL -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/contenedorContenido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Título -->
                <TextView
                    android:id="@+id/tvTituloContenedor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona una opción"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/caviardreams"
                    android:layout_marginBottom="12dp"/>
                <!-- Recycler -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerOpciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerEdad"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="40dp"
                    android:overScrollMode="never"
                    android:visibility="gone"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
