<!-- layout/item_avatar_container.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- RadioGroup para seleccionar género -->
    <RadioGroup
        android:id="@+id/radiogroupgenero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:buttonTint="@color/azulgourmeet"
        android:layout_marginBottom="16dp">
        <RadioButton
            android:id="@+id/rbmasculino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masculino"
            android:fontFamily="@font/caviardreams"
            android:textSize="16sp"
            android:checked="true"
            android:layout_marginEnd="24dp"/>

        <RadioButton
            android:id="@+id/rbfemenino"
            android:fontFamily="@font/caviardreams"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Femenino"
            android:textSize="16sp"/>
    </RadioGroup>
    <Button
        android:id="@+id/btnGoogleAvatar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Usar foto de Google"
        android:visibility="gone"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/azulgourmeet"
        android:textColor="@android:color/white"
        android:fontFamily="@font/caviardreams"/>
    <!-- GridLayout para avatares -->
    <GridLayout
        android:id="@+id/gridavatares"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:padding="8dp"/>
</LinearLayout>