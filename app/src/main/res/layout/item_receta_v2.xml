<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="350dp"
    android:layout_margin="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImagen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginTop="35dp"
            android:layout_marginBottom="0dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/imgReceta"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/degradado_azul"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#00000000"/>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================= -->
        <!-- DEGRADADO -->
        <!-- ========================= -->

        <!-- Overlay -->

        <!-- ========================= -->
        <!-- CONTENEDOR TITULO -->
        <!-- ========================= -->

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTitulo"
            android:layout_width="230dp"
            android:layout_height="55dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="0dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="9dp"
            app:cardBackgroundColor="#177AFF"
            app:strokeWidth="0dp"
            android:translationZ="-10dp"
            app:strokeColor="#111111">
            <TextView
                android:layout_marginTop="-17dp"
                android:id="@+id/txtTitulo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:fontFamily="@font/caviardreams"
                android:gravity="center"
                android:maxLines="2"
                android:paddingHorizontal="12dp"
                android:text="Enchiladas Verdes"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================= -->
        <!-- CONTENEDOR ESTADISTICAS -->
        <!-- ========================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            android:layout_width="255dp"
            android:layout_height="30dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="51dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#33FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <!-- Tiempo -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_clock_bg" />

                    <TextView
                        android:id="@+id/txtTiempo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caviardreams"
                        android:text="50 min"
                        android:textColor="#303030"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                </LinearLayout>
                <!-- Nivel -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_gorrito_nuevo_azul" />

                    <TextView
                        android:id="@+id/txtNivel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caviardreams"
                        android:text="Fácil"
                        android:textColor="#303030"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Costo -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_dinero" />

                    <TextView
                        android:id="@+id/txtCosto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caviardreams"
                        android:text="$45"
                        android:textColor="#303030"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Tipo -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_comida" />

                    <TextView
                        android:id="@+id/txtTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/caviardreams"
                        android:text="Snak"
                        android:textColor="#303030"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================= -->
        <!-- CONTENEDOR INFERIOR -->
        <!-- ========================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIngredientes"
            android:layout_width="255dp"
            android:layout_height="55dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"

            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#AA177AFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvIngredientes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:overScrollMode="never"
                    android:scrollbars="horizontal"/>

                <!-- Coincidencia -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="8dp"

                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="#6685AFFF"
                    app:cardElevation="2dp">

                    <TextView
                        android:id="@+id/txtCoincidencia"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="35%"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="11sp"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</androidx.cardview.widget.CardView>